# ─── Entorno ─────────────────────────────────────────────────
# development | production
NODE_ENV=development

# ─── Base de datos ───────────────────────────────────────────
DATABASE_URL=
# Sincronizar esquema en desarrollo (true|false). Ignorado en production.
DB_SYNCHRONIZE=true
# Borrar todas las tablas al arrancar (true|false). Default false. ¡Peligroso en production!
DB_DROP_SCHEMA=false
# Ejecutar seeders al arrancar (true|false). Default false. Ignorado en production.
SEED_ON_STARTUP=false
    
# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=

# ─── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_CLOUD_API_KEY=
CLOUDINARY_CLOUD_API_SECRET=
CLOUDINARY_URL=

# ─── Brevo (Transactional Email) ─────────────────────────────
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_CC=

# ─── Frontend ────────────────────────────────────────────────
URL_CLIENT=

# ─── Seeder admin ────────────────────────────────────────────
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ─── Server ──────────────────────────────────────────────────
PORT=3000